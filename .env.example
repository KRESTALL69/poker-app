# Copy to .env on the VPS (chmod 600) — never commit the real file.

# --- Supabase (still required: EmailAuth, avatar Storage, Realtime are not
# migrated to Postgres yet — see docs/POSTGRES_MIGRATION_ARCHITECTURE.md,
# "Known limitations") ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
SUPPORT_ADMIN_CHAT_ID=

# --- Google Sheets ---
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Session ---
SESSION_SECRET=

# --- PostgreSQL (reuses the shared poker-clock-db container — see
# docs/VPS_DEPLOYMENT.md; not a new poker-postgres service) ---
DATABASE_PROVIDER=supabase
DATABASE_URL=postgresql://poker_app:CHANGE_ME@poker-clock-db:5432/poker_app
