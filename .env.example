# Copy to .env on the VPS (chmod 600) — never commit the real file.
# No Supabase, no Vercel — every variable below is read by this app directly.

# Public URL of the deployed app — used to build absolute links (avatar URLs).
NEXT_PUBLIC_APP_URL=https://www.dontworryclub.pro

# --- Telegram ---
# Bot token — verifies Mini App initData, Login Widget hash, and drives the webhook/bot API calls.
TELEGRAM_BOT_TOKEN=
# Telegram chat_id of the admin group that receives forwarded support messages.
SUPPORT_ADMIN_CHAT_ID=

# --- Google Sheets (tournament results export/import) ---
# Service account email for the Google Sheets API.
GOOGLE_CLIENT_EMAIL=
# Service account private key (keep the \n-escaped PEM format as issued by Google).
GOOGLE_PRIVATE_KEY=
# Target spreadsheet ID.
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Email (Resend) — self-hosted OTP delivery, see docs/AUTH_MIGRATION.md ---
# Resend API key.
RESEND_API_KEY=
# Verified sender address/domain for OTP emails.
EMAIL_FROM=

# --- Session ---
# HMAC key for the session cookie (lib/telegram-web-session.ts) and the email OTP hash (lib/email-otp.ts).
SESSION_SECRET=

# --- PostgreSQL ---
# Connection string. On the VPS this points at the shared poker-clock-db
# container (separate database + role, not a dedicated Postgres instance) —
# see docs/VPS_DEPLOYMENT.md.
DATABASE_URL=postgresql://poker_app:CHANGE_ME@poker-clock-db:5432/poker_app
