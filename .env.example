# Copy to .env on the VPS (chmod 600) — never commit the real file.

# --- Public app URL (used to build absolute avatar URLs — LocalAvatarStorageRepository —
# and to construct the OTP email's implicit context) ---
NEXT_PUBLIC_APP_URL=https://www.dontworryclub.pro

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
SUPPORT_ADMIN_CHAT_ID=

# --- Google Sheets ---
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Email (Resend) — self-hosted OTP delivery, see docs/AUTH_MIGRATION.md.
# Not Supabase Auth — Supabase has been fully decommissioned. ---
RESEND_API_KEY=
EMAIL_FROM=

# --- Session (also keys the email OTP hash — see lib/email-otp.ts) ---
SESSION_SECRET=

# --- PostgreSQL (reuses the shared poker-clock-db container — see
# docs/VPS_DEPLOYMENT.md; not a new poker-postgres service) ---
DATABASE_URL=postgresql://poker_app:CHANGE_ME@poker-clock-db:5432/poker_app
